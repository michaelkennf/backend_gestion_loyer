// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  OWNER
}

enum PropertyType {
  HOUSE
  STUDIO
  LAND
}

enum ExpenseType {
  COMMON
  PRIVATE
}

enum PaymentKind {
  RENTAL_RENT
  MONTHLY_PAYMENT
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  fullName       String
  passwordHash   String
  role           Role
  forceReset     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdHouses  House[]
  createdStudios Studio[]
  createdLands   Land[]
  payments       Payment[]
  expenses       Expense[]
  suppliers      Supplier[]
  comments       Comment[]
  refreshTokens  RefreshToken[]
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contact     String
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expenses    Expense[]

  @@index([name])
}

model House {
  id           String    @id @default(cuid())
  address      String
  floors       Int
  apartments   Int
  rentPrice    Float
  layout       Json      @default("[]")
  /// Si true : immeuble (formulaire dédié). Si false : maison.
  isBuilding   Boolean   @default(false)
  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  payments     Payment[]
  expenses     Expense[]
}

model Studio {
  id           String    @id @default(cuid())
  address      String
  monthlyRent  Float
  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  payments     Payment[]
  expenses     Expense[]
}

model Land {
  id           String    @id @default(cuid())
  address      String
  size         Float
  monthlyRent  Float
  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  expenses     Expense[]
  payments     Payment[]
}

model Payment {
  id            String       @id @default(cuid())
  propertyType  PropertyType
  paymentKind   PaymentKind  @default(MONTHLY_PAYMENT)
  tenantName    String?
  contractFilePath String?
  month         String
  monthsCount   Int?
  amount        Float
  notes         String?
  floor         Int?
  apartmentNumber Int?
  date          DateTime
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  houseId       String?
  house         House?       @relation(fields: [houseId], references: [id], onDelete: SetNull)
  studioId      String?
  studio        Studio?      @relation(fields: [studioId], references: [id], onDelete: SetNull)
  landId        String?
  land          Land?        @relation(fields: [landId], references: [id], onDelete: SetNull)
  comments      Comment[]
  createdAt     DateTime     @default(now())

  @@index([month])
}

model Expense {
  id              String       @id @default(cuid())
  expenseType     ExpenseType
  propertyType    PropertyType
  apartmentNumber String?
  category        String
  amount          Float
  comment         String?
  date            DateTime
  createdById     String
  createdBy       User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  houseId         String?
  house           House?       @relation(fields: [houseId], references: [id], onDelete: SetNull)
  studioId        String?
  studio          Studio?      @relation(fields: [studioId], references: [id], onDelete: SetNull)
  landId          String?
  land            Land?        @relation(fields: [landId], references: [id], onDelete: SetNull)
  supplierId      String?
  supplier        Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  comments        Comment[]
  createdAt       DateTime     @default(now())
}

model Comment {
  id         String    @id @default(cuid())
  content    String
  paymentId  String?
  expenseId  String?
  payment    Payment?  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  expense    Expense?  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}
